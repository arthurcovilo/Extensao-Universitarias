<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@drawable/bg_card_evento"
    android:layout_marginBottom="14dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/txtTituloEvento"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Distribuição de Alimentos"
            android:textColor="#222222"
            android:textSize="22sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/txtVagas"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@android:drawable/btn_default_small"
            android:paddingLeft="10dp"
            android:paddingTop="6dp"
            android:paddingRight="10dp"
            android:paddingBottom="6dp"
            android:text="20"
            android:textColor="#D32F2F"
            android:textStyle="bold"/>

    </LinearLayout>

    <TextView
        android:id="@+id/txtDataEvento"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="15/11/2025"
        android:textColor="#666666"
        android:textSize="16sp"/>

    <TextView
        android:id="@+id/txtLocalEvento"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Centro Comunitário - São Paulo"
        android:textColor="#666666"
        android:textSize="16sp" />

    <TextView
        android:id="@+id/txtDescricaoEvento"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="Ajude na distribuição de cestas básicas para famílias carentes."
        android:textColor="#444444"
        android:textSize="15sp" />

    <Button
        android:id="@+id/btnInscrever"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:background="@drawable/bg_botao_inscrever"
        android:text="Inscrever-se"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:textStyle="bold" />

</LinearLayout>