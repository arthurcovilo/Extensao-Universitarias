<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="14dp"
    tools:background="@drawable/bg_card_evento"
    tools:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        tools:ignore="UselessParent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/txtTituloEvento4"
                android:layout_width="338dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Distribuição de Alimentos"
                android:textColor="#222222"
                android:textSize="22sp"
                android:textStyle="bold" />

        </LinearLayout>

        <TextView
            android:id="@+id/txtDataEvento4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="15/11/2025"
            android:textColor="#666666"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/txtLocalEvento4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Centro Comunitário - São Paulo"
            android:textColor="#666666"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/txtDescricaoEvento4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Ajude na distribuição de cestas básicas para famílias carentes."
            android:textColor="#444444"
            android:textSize="15sp" />

    </LinearLayout>
</LinearLayout>