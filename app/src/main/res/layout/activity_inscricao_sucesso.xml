<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7F7F7">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <!-- Ícone de Sucesso -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✓"
            android:textSize="80sp"
            android:textColor="#4CAF50"
            android:textStyle="bold"
            android:layout_marginTop="40dp"
            android:layout_marginBottom="16dp" />

        <!-- Mensagem Principal -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Inscrição realizada\ncom sucesso!"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#222222"
            android:gravity="center"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Você está inscrito no evento:"
            android:textSize="16sp"
            android:textColor="#666666"
            android:gravity="center"
            android:layout_marginBottom="24dp" />

        <!-- Card com Informações do Evento -->
        <LinearLayout
            android:orientation="vertical"
            android:background="@drawable/bg_card_evento"
            android:padding="20dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp">

            <TextView
                android:id="@+id/txtTituloEventoSucesso"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nome do Evento"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#222222"
                android:layout_marginBottom="16dp" />

            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📅 "
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/txtDataEventoSucesso"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="15/11/2025"
                    android:textSize="16sp"
                    android:textColor="#444444" />

            </LinearLayout>

            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📍 "
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/txtLocalEventoSucesso"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Local do Evento"
                    android:textSize="16sp"
                    android:textColor="#444444" />

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#EEEEEE"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🕐 "
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/txtDataInscricaoSucesso"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Inscrito em: 20/04/2026 às 14:30"
                    android:textSize="14sp"
                    android:textColor="#888888" />

            </LinearLayout>

        </LinearLayout>

        <!-- Mensagem Informativa -->
        <LinearLayout
            android:orientation="vertical"
            android:background="#E8F5E9"
            android:padding="16dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="ℹ️ Informação Importante"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#2E7D32"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Sua inscrição foi registrada e será utilizada pela organização para controle de participantes. Compareça no dia e horário do evento!"
                android:textSize="14sp"
                android:textColor="#2E7D32"
                android:lineSpacingExtra="4dp" />

        </LinearLayout>

        <!-- Botões de Ação -->
        <Button
            android:id="@+id/btnVerDetalhesEvento"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ver Detalhes do Evento"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#1976D2"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnVoltarEventos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Voltar para Lista de Eventos"
            android:textAllCaps="false"
            android:textColor="#444444"
            android:backgroundTint="#EEEEEE"
            android:layout_marginBottom="40dp" />

    </LinearLayout>
</ScrollView>
